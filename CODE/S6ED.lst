  1+  0690              ;                                       ****************************************
  2+  0690              ;                                       * MAPPER MANAGER                       *
  3+  0690              ;                                       ****************************************
  4+  0690              ;
  5+  0690              ; USES DOS2/NEXTOR MAPPER SUPPORT ROUTINES FOUND VIA EXTBIO.
  6+  0690              ; NEVER USE OUT (#0FE) DIRECTLY — ALWAYS GO THROUGH MPUTP2.
  7+  0690              ;
  8+  0690              ; INIT: CALL MAPINIT AT STARTUP. STORES ENTRY ADDRESSES IN VARS.
  9+  0690              ; AFTER INIT: CALL ALLSEG, FRESEG, RDSEG, WRSEG, PUTP1, GETP1, PUTP2, GETP2.
 10+  0690
 11+  0690
 12+  0690              ; --- MAPINIT                   ----------------------------------------
 13+  0690
 14+  0690              ; - MAPINIT ----------
 15+  0690              ; - LOCATE MAPPER MANAGER VIA EXTBIO
 16+  0690              ; - FILL MAP_XXX JUMP TABLE ENTRIES IN VARS
 17+  0690              ; - OUTPUT:
 18+  0690              ; -     CY = 1  NO MAPPER MANAGER (NO EXTENDED BIOS OR DEVICE NOT PRESENT)
 19+  0690              ; -
 20+  0690
 21+  0690              MAPINIT         ; CHECK HOKVLD BIT 0: EXTENDED BIOS PRESENT?
 22+  0690 3A 20 FB                     LD      A, (HOKVLD)
