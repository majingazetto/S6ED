 32+  042A
 33+  042A              ; --- STRING                           ----------------------------------------
 34+  042A
 35+  042A
 36+  042A              ; COMBINED ROUTINE FOR CONVERSION OF DIFFERENT SIZED BINARY NUMBERS INTO
 37+  042A              ; DIRECTLY PRINTABLE ASCII(Z)-STRING
 38+  042A              ; INPUT VALUE IN REGISTERS, NUMBER SIZE AND -RELATED TO THAT- REGISTERS TO FILL
 39+  042A              ; IS SELECTED BY CALLING THE CORRECT ENTRY:
 40+  042A              ;
 41+  042A              ;  ENTRY  INPUTREGISTER(S)  DECIMAL VALUE 0 TO:
 42+  042A              ;   B2D8             A                    255  (3 DIGITS)
 43+  042A              ;   B2D16           HL                  65535   5   "
 44+  042A              ;   B2D24         E:HL               16777215   8   "
 45+  042A              ;   B2D32        DE:HL             4294967295  10   "
 46+  042A              ;   B2D48     BC:DE:HL        281474976710655  15   "
 47+  042A              ;   B2D64  IX:BC:DE:HL   18446744073709551615  20   "
 48+  042A              ;
 49+  042A              ; THE RESULTING STRING IS PLACED INTO A SMALL BUFFER ATTACHED TO THIS ROUTINE,
 50+  042A              ; THIS BUFFER NEEDS NO INITIALIZATION AND CAN BE MODIFIED AS DESIRED.
 51+  042A              ; THE NUMBER IS ALIGNED TO THE RIGHT, AND LEADING 0'S ARE REPLACED WITH SPACES.
 52+  042A              ; ON EXIT HL POINTS TO THE FIRST DIGIT, (B)C = NUMBER OF DECIMALS
 53+  042A              ; THIS WAY ANY RE-ALIGNMENT / POSTPROCESSING IS MADE EASY.
 54+  042A              ; CHANGES: AF,BC,DE,HL,IX
 55+  042A              ; P.S. SOME EXAMPLES BELOW
 56+  042A
 57+  042A              ; BY ALWIN HENSELER
 58+  042A
 59+  042A
 60+  042A 26 00        B2D8            LD      H,0
 61+  042C 6F                           LD      L,A
 62+  042D 1E 00        B2D16           LD      E,0
 63+  042F 16 00        B2D24           LD      D,0
 64+  0431 01 00 00     B2D32           LD      BC,0
 65+  0434 DD 21 00 00  B2D48           LD      IX,0            ; ZERO ALL NON-USED BITS
 66+  0438 22 EC 0A     B2D64           LD      (B2DINV),HL
 67+  043B ED 53 EE 0A                  LD      (B2DINV + 2),DE
 68+  043F ED 43 F0 0A                  LD      (B2DINV + 4),BC
 69+  0443 DD 22 F2 0A                  LD      (B2DINV + 6),IX ; PLACE FULL 64-BIT INPUT VALUE IN BUFFER
 70+  0447 21 F4 0A                     LD      HL,B2DBUF
 71+  044A 11 F5 0A                     LD      DE,B2DBUF + 1
 72+  044D 36 20                        LD      (HL)," "
 73+  044F              B2DFILC         EQU     $ - 1           ; ADDRESS OF FILL-CHARACTER
 74+  044F 01 12 00                     LD      BC,18
 75+  0452 ED B0                        LDIR                    ; FILL 1ST 19 BYTES OF BUFFER WITH SPACES
 76+  0454 ED 43 07 0B                  LD      (B2DEND-1),BC   ; SET BCD VALUE TO "0" & PLACE TERMINATING 0
 77+  0458 1E 01                        LD      E,1             ; NO. OF BYTES IN BCD VALUE
 78+  045A 21 F4 0A                     LD      HL,B2DINV + 8   ; (ADDRESS MSB INPUT)+1
 79+  045D 01 09 09                     LD      BC,#0909
 80+  0460 AF                           XOR     A
 81+  0461 05           B2DSKP0         DEC     B
 82+  0462 28 29                        JR      Z,B2DSIZ        ; ALL 0: CONTINUE WITH POSTPROCESSING
 83+  0464 2B                           DEC     HL
 84+  0465 B6                           OR      (HL)            ; FIND FIRST BYTE <>0
 85+  0466 28 F9                        JR      Z,B2DSKP0
 86+  0468 0D           B2DFND1         DEC     C
 87+  0469 17                           RLA
 88+  046A 30 FC                        JR      NC,B2DFND1      ; DETERMINE NO. OF MOST SIGNIFICANT 1-BIT
 89+  046C 1F                           RRA
 90+  046D 57                           LD      D,A             ; BYTE FROM BINARY INPUT VALUE
 91+  046E E5           B2DLUS2         PUSH    HL
 92+  046F C5                           PUSH    BC
 93+  0470 21 07 0B     B2DLUS1         LD      HL,B2DEND - 1   ; ADDRESS LSB OF BCD VALUE
 94+  0473 43                           LD      B,E             ; CURRENT LENGTH OF BCD VALUE IN BYTES
 95+  0474 CB 12                        RL      D               ; HIGHEST BIT FROM INPUT VALUE -> CARRY
 96+  0476 7E           B2DLUS0         LD      A,(HL)
 97+  0477 8F                           ADC     A,A
 98+  0478 27                           DAA
 99+  0479 77                           LD      (HL),A          ; DOUBLE 1 BCD BYTE FROM INTERMEDIATE RESULT
100+  047A 2B                           DEC     HL
101+  047B 10 F9                        DJNZ    B2DLUS0         ; AND GO ON TO DOUBLE ENTIRE BCD VALUE (+CARRY!)
102+  047D 30 03                        JR      NC,B2DNXT
103+  047F 1C                           INC     E               ; CARRY AT MSB -> BCD VALUE GREW 1 BYTE LARGER
104+  0480 36 01                        LD      (HL),1          ; INITIALIZE NEW MSB OF BCD VALUE
105+  0482 0D           B2DNXT          DEC     C
106+  0483 20 EB                        JR      NZ,B2DLUS1      ; REPEAT FOR REMAINING BITS FROM 1 INPUT BYTE
107+  0485 C1                           POP     BC              ; NO. OF REMAINING BYTES IN INPUT VALUE
108+  0486 0E 08                        LD      C,8             ; RESET BIT-COUNTER
109+  0488 E1                           POP     HL              ; POINTER TO BYTE FROM INPUT VALUE
110+  0489 2B                           DEC     HL
111+  048A 56                           LD      D,(HL)          ; GET NEXT GROUP OF 8 BITS
112+  048B 10 E1                        DJNZ    B2DLUS2         ; AND REPEAT UNTIL LAST BYTE FROM INPUT VALUE
113+  048D 21 08 0B     B2DSIZ          LD      HL,B2DEND       ; ADDRESS OF TERMINATING 0
114+  0490 4B                           LD      C,E             ; SIZE OF BCD VALUE IN BYTES
115+  0491 B7                           OR      A
116+  0492 ED 42                        SBC     HL,BC           ; CALCULATE ADDRESS OF MSB BCD
117+  0494 54                           LD      D,H
118+  0495 5D                           LD      E,L
119+  0496 ED 42                        SBC     HL,BC
120+  0498 EB                           EX      DE,HL           ; HL=ADDRESS BCD VALUE, DE=START OF DECIMAL VALUE
121+  0499 41                           LD      B,C             ; NO. OF BYTES BCD
122+  049A CB 21                        SLA     C               ; NO. OF BYTES DECIMAL (POSSIBLY 1 TOO HIGH)
123+  049C 3E 30                        LD      A,'0'
124+  049E ED 6F                        RLD                     ; SHIFT BITS 4-7 OF (HL) INTO BIT 0-3 OF A
125+  04A0 FE 30                        CP      '0'             ; (HL) WAS > #9?
126+  04A2 20 06                        JR      NZ,B2DEXPH      ; IF YES, START WITH RECORDING HIGH DIGIT
127+  04A4 0D                           DEC     C               ; CORRECT NUMBER OF DECIMALS
128+  04A5 13                           INC     DE              ; CORRECT START ADDRESS
129+  04A6 18 04                        JR      B2DEXPL         ; CONTINUE WITH CONVERTING LOW DIGIT
130+  04A8 ED 6F        B2DEXP          RLD                     ; SHIFT HIGH DIGIT (HL) INTO LOW DIGIT OF A
131+  04AA 12           B2DEXPH         LD      (DE),A          ; RECORD RESULTING ASCII-CODE
132+  04AB 13                           INC     DE
133+  04AC ED 6F        B2DEXPL         RLD
134+  04AE 12                           LD      (DE),A
135+  04AF 13                           INC     DE
136+  04B0 23                           INC     HL              ; NEXT BCD-BYTE
137+  04B1 10 F5                        DJNZ    B2DEXP          ; AND GO ON TO CONVERT #EAC BCD-BYTE INTO 2 ASCII
138+  04B3 ED 42                        SBC     HL,BC           ; RETURN WITH HL POINTING TO 1ST DECIMAL
139+  04B5 C9                           RET
