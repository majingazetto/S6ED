 53+  015A              ; - BUILDFCB ---------
 54+  015A              ; - CLEAN FCB
 55+  015A              ; - AND COPY FILENAME
 56+  015A              ; - HL: FILENAME
 57+  015A
 58+  015A E5           BUILDFCB        PUSH    HL
 59+  015B 21 7D 14                     LD      HL,FCB
 60+  015E 11 7E 14                     LD      DE,FCB + 1
 61+  0161 01 24 00                     LD      BC,36
 62+  0164 36 00                        LD      (HL),0
 63+  0166 ED B0                        LDIR
 64+  0168 21 7E 14                     LD     HL,FCB + FFILNAME
 65+  016B 11 7F 14                     LD     DE,FCB + FFILNAME + 1
 66+  016E 01 0A 00                     LD     BC,10
 67+  0171 36 20                        LD     (HL),' '
 68+  0173 ED B0                        LDIR
 69+  0175 E1                           POP     HL
 70+  0176
 71+  0176 11 7E 14                     LD      DE,FCB + FFILNAME
 72+  0179
 73+  0179 7E           .NAME           LD      A,(HL)
 74+  017A 23                           INC     HL
 75+  017B A7                           AND     A
 76+  017C 28 14                        JR      Z,.END
 77+  017E FE 2E                        CP      '.'
