  4+  0684              ;
  5+  0684              ; READS THE MSX ROM 6×8 CHARSET (256 GLYPHS × 8 BYTES, 1BPP, BITS 7-2 USED).
  6+  0684              ; EXPANDS INTO 4 VRAM FONT TABLES: NORMAL / BOLD / ITALIC / BOLD+ITALIC.
  7+  0684              ; CALLED ONCE AT STARTUP BEFORE ANY RENDERING.
  8+  0684              ;
  9+  0684              ; ROM CHARSET ACCESS: RDSLT FROM SLOT 0, ADDRESS IN CGPNT.
 10+  0684
 11+  0684
 12+  0684              ; --- ITALIC SHIFT TABLE        ----------------------------------------
 13+  0684
 14+  0684                              ; ROW SHIFT OFFSETS FOR ITALIC (POSITIVE = SHIFT PIXELS LEFT)
 15+  0684                              ; APPLIED PER-ROW WHEN GENERATING ITALIC GLYPHS
 16+  0684 01 01 01 01  ITALSHFT      DEFB    1, 1, 1, 1, 0, -1, -1, -1
 16+  0688 00 FF FF FF
 17+  068C
 18+  068C
 19+  068C              ; --- FONTINIT                  ----------------------------------------
 20+  068C
 21+  068C              ; - FONTINIT ---------
 22+  068C              ; - EXPAND ROM CHARSET TO 4 VRAM FONT TABLES
 23+  068C              ; - CALLED ONCE AT INIT
 24+  068C              ; -
 25+  068C
 26+  068C              FONTINIT        ; TODO:
 27+  068C                              ; 1. READ CGPNT TO GET CHARSET SLOT AND BASE ADDRESS
 28+  068C                              ; 2. FOR #EAC OF 256 GLYPHS (N = 0..255):
 29+  068C                              ;    A. READ 8 BYTES FROM ROM VIA RDSLT
 30+  068C                              ;    B. EXPAND TO NORMAL:   BITS 7-2 → 6PX OF COLOR 0/1, PAD 2 RIGHT PX
 31+  068C                              ;    C. EXPAND TO BOLD:     NORMAL_ROW | (NORMAL_ROW >> 1)
 32+  068C                              ;    D. EXPAND TO ITALIC:   NORMAL_ROW SHIFTED PER ITALSHFT TABLE
 33+  068C                              ;    E. EXPAND TO B+I:      BOLD TRANSFORM THEN ITALIC SHIFT
 34+  068C                              ;    F. UPLOAD #EAC VARIANT TO ITS VRAM FONT TABLE VIA HMMC OR OTIR
 35+  068C                              ; 3. #EAC GLYPH = 16 BYTES IN VRAM (6PX × 8 ROWS = 2 B/ROW × 8 = 16)
 36+  068C                              ;    GLYPH N: SX = (N % 32) * 6, SY = TABLE_SY + (N / 32) * 8
 37+  068C C9                           RET
 38+  068D
 39+  068D
