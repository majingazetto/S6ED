 54+  072A 54                           LD      D, H
 55+  072B 5D                           LD      E, L            ; DE = HL*2
 56+  072C 29                           ADD     HL, HL          ; OOPS — NEED HL*3 NOT HL*4
 57+  072D                              ; CORRECT: HL*3 = HL*2 + HL (ORIGINAL)
 58+  072D                              ; ENTRY ADDRESS = DIRPAGE + LINE*3
 59+  072D                              ; TODO: IMPLEMENT PROPERLY (16-BIT MULTIPLY BY 3)
