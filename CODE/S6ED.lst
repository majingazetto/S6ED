121+  0729 21 00 00                     LD      HL, 0           ; HL = EXPANDED ROW
122+  072C
123+  072C                              ; PIXEL 0 (BIT 7)
124+  072C CB 78                        BIT     7, B
125+  072E 28 04                        JR      Z, .P1
126+  0730 CB FC                        SET     7, H
127+  0732 CB F4                        SET     6, H
128+  0734              .P1             ; PIXEL 1 (BIT 6)
129+  0734 CB 70                        BIT     6, B
130+  0736 28 04                        JR      Z, .P2
131+  0738 CB EC                        SET     5, H
132+  073A CB E4                        SET     4, H
133+  073C              .P2             ; PIXEL 2 (BIT 5)
134+  073C CB 68                        BIT     5, B
135+  073E 28 04                        JR      Z, .P3
136+  0740 CB DC                        SET     3, H
137+  0742 CB D4                        SET     2, H
138+  0744              .P3             ; PIXEL 3 (BIT 4)
139+  0744 CB 60                        BIT     4, B
140+  0746 28 04                        JR      Z, .P4
141+  0748 CB CC                        SET     1, H
142+  074A CB C4                        SET     0, H
143+  074C              .P4             ; PIXEL 4 (BIT 3)
144+  074C CB 58                        BIT     3, B
145+  074E 28 04                        JR      Z, .P5
146+  0750 CB FD                        SET     7, L
147+  0752 CB F5                        SET     6, L
148+  0754              .P5             ; PIXEL 5 (BIT 2)
149+  0754 CB 50                        BIT     2, B
150+  0756 28 04                        JR      Z, .DONE
151+  0758 CB ED                        SET     5, L
152+  075A CB E5                        SET     4, L
153+  075C
154+  075C 7C           .DONE           LD      A, H
155+  075D 12                           LD      (DE), A
156+  075E 13                           INC     DE
157+  075F 7D                           LD      A, L
158+  0760 12                           LD      (DE), A
159+  0761 1B                           DEC     DE              ; RESTORE DE TO START OF 2-BYTE ROW
160+  0762 C1                           POP     BC
