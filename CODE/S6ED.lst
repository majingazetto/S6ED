 55+  068E              ; - A: ROM ROW BYTE
 56+  068E              ; -
 57+  068E
 58+  068E              EXPBOLD         ; TODO: A = A | (A >> 1), THEN EXPNORM
 59+  068E C9                           RET
 60+  068F
 61+  068F
 62+  068F              ; - EXPITAL ----------
