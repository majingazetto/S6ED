 35+  0000              STBROW          EQU     25              ; STATUS BAR ROW
 36+  0000
 37+  0000
 38+  0000              ; --- VRAM MAP                  ----------------------------------------
 39+  0000
 40+  0000
 41+  0000              VR_DISP         EQU     #00000          ; DISPLAY BITMAP (128 B/LINE × 212 LINES)
 42+  0000              VR_SAT          EQU     #06A00          ; SPRITE ATTRIBUTE TABLE
 43+  0000              VR_SGT          EQU     #06C00          ; SPRITE GENERATOR TABLE
 44+  0000
 45+  0000              VR_FNORM        EQU     #07000          ; FONT: NORMAL        (256 × 16 BYTES)
 46+  0000              VR_FBOLD        EQU     #08000          ; FONT: BOLD
 47+  0000              VR_FITAL        EQU     #09000          ; FONT: ITALIC
 48+  0000              VR_FBI          EQU     #0A000          ; FONT: BOLD+ITALIC
 49+  0000
 50+  0000                              ; FONT TABLE GEOMETRY (ALL TABLES IDENTICAL STRUCTURE)
 51+  0000                              ;   32 GLYPHS PER ROW → 8 ROWS (256 TOTAL)
 52+  0000                              ;   GLYPH N: SX = (N % 32) * 6,  SY = TABLE_SY + (N / 32) * 8
 53+  0000                              ;   TABLE_SY = (VR_FXXX - VR_DISP) / 128
 54+  0000              FNORM_SY        EQU     (VR_FNORM - VR_DISP) / 128     ; = 56
 55+  0000              FBOLD_SY        EQU     (VR_FBOLD - VR_DISP) / 128     ; = 64
 56+  0000              FITAL_SY        EQU     (VR_FITAL - VR_DISP) / 128     ; = 72
 57+  0000              FBI_SY          EQU     (VR_FBI   - VR_DISP) / 128     ; = 80
 58+  0000
 59+  0000
 60+  0000              ; --- PALETTE                   ----------------------------------------
 61+  0000
 62+  0000
 63+  0000                              ; COLOR INDICES (SCREEN 6, 4 COLORS)
 64+  0000              COL_BG          EQU     0               ; BACKGROUND
 65+  0000              COL_FG          EQU     1               ; NORMAL TEXT / FOREGROUND
 66+  0000              COL_UI          EQU     2               ; UI CHROME (GUTTERS, MENU, STATUS)
 67+  0000              COL_HI          EQU     3               ; CURSOR / HIGHLIGHT / ACCENT
 68+  0000
 69+  0000
