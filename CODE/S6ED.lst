111+  0730                              ;    OLD_BYTES = 1 + OLD*2
112+  0730                              ;    NEW_BYTES = 1 + WORKBUF[0]*2
113+  0730                              ; 4. IF NEW_BYTES == OLD_BYTES: LDIR WORKBUF → TXPAGE+DE
