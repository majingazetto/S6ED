 76+  0000              ATRUNDR       EQU     #04             ; BIT 2
 77+  0000              ATRINV        EQU     #08             ; BIT 3  (INVERSE VIDEO)
 78+  0000              ATRFMSK   EQU     #03             ; BITS 0-1 → FONT VARIANT INDEX
 79+  0000
 80+  0000
