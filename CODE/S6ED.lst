 24+  0694 D0                           RET     NC              ; BIT 0 = 0: NO EXTENDED BIOS
 25+  0695
 26+  0695                              ; CALL EXTBIO: D=4 (MAPPER DEVICE), E=2 (GET JUMP TABLE)
 27+  0695 AF                           XOR     A               ; A=0
 28+  0696 16 04                        LD      D, MAP_DEV
 29+  0698 1E 02                        LD      E, MAPFNTBL
 30+  069A CD CA FF                     CALL    EXTBIO          ; HL = JUMP TABLE BASE
 31+  069D                              ; IX, IY, ALTERNATE REGS CORRUPTED BY EXTBIO — DO NOT USE
