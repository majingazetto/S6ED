 28+  0728
 29+  0728              BUFINIT         ; TODO:
 30+  0728                              ; 1. ALLSEG (USER) → A = DIR SEGMENT; STORE IN DIRSEG
 31+  0728                              ;    PUTP1 A        → BANK IT INTO PAGE 1 (DIRPAGE)
 32+  0728                              ; 2. ALLSEG (USER) → A = FIRST TEXT SEGMENT; STORE IN TXSEG
 33+  0728                              ;    PUTP2 A        → BANK IT INTO PAGE 2 (TXPAGE)
 34+  0728                              ; 3. WRITE EMPTY LINE RECORD AT TXPAGE+0: DEFB 0
 35+  0728                              ; 4. WRITE DIR ENTRY 0: (DIRPAGE+0) = TXSEG, (DIRPAGE+1) = 0, (DIRPAGE+2) = 0
 36+  0728                              ; 5. TOTLINES = 1, TOPLINE = 0, DOCLINE = 0, CURX = 0, CURY = 0
 37+  0728 C9                           RET
