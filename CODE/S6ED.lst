 61+  06C6 22 34 09                     LD      (MPUTP1), HL
 62+  06C9
 63+  06C9 E1                           POP     HL
 64+  06CA E5                           PUSH    HL
 65+  06CB 11 21 00                     LD      DE, MJGETP1
 66+  06CE 19                           ADD     HL, DE
 67+  06CF 22 36 09                     LD      (MGETP1), HL
 68+  06D2
 69+  06D2 E1                           POP     HL
 70+  06D3 E5                           PUSH    HL
