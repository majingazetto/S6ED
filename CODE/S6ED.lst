121+  06FC              ; - A:  SEGMENT NUMBER
122+  06FC              ; - HL: ADDRESS WITHIN SEGMENT (TOP 2 BITS IGNORED)
123+  06FC              ; - OUTPUT:
124+  06FC              ; -     A: BYTE READ
125+  06FC              ; - NOTE: RETURNS WITH INTERRUPTS DISABLED
126+  06FC              ; -
127+  06FC
128+  06FC 2A 30 09     RDSEG           LD      HL, (MRDSEG)
