 43+  068D              ; - EXPAND ONE 1BPP ROM ROW BYTE TO 2-BYTE VRAM ROW (NORMAL, SCREEN 6 2BPP)
 44+  068D              ; - A:  ROM ROW BYTE (BITS 7-2 = 6 PIXELS)
 45+  068D              ; - HL: DESTINATION VRAM ROW BUFFER (2 BYTES)
 46+  068D              ; - NOTE: COLOR 1 = PIXEL ON, COLOR 0 = PIXEL OFF
 47+  068D              ; -
 48+  068D
 49+  068D              EXPNORM         ; TODO
 50+  068D C9                           RET
 51+  068E
 52+  068E
