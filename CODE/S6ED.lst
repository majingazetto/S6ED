108+  06F3              ; -     FC = 1  ERROR (INVALID OR ALREADY FREE)
109+  06F3              ; -
110+  06F3
111+  06F3 06 00        FRESEG          LD      B, 0            ; B=0: PRIMARY MAPPER
112+  06F5 2A 2E 09                     LD      HL, (MFRESEG)
